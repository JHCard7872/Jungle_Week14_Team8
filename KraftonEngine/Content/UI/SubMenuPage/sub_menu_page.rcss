    display: none;
}

/* 스코어보드 prev/next 페이지 이동 — 5명 단위, Lua가 페이지 번호 갱신 */
#scoreboard_pagination {
    position: absolute;
    right: 20px;
    bottom: 16px;
    width: 220px;
    height: 52px;
}

.scoreboard_nav_button {
