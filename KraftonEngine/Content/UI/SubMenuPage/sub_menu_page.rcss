/* 중앙 하단 Confirm 버튼: ui_button(_hover) 사용 */
.horiz_button {
    position: absolute;
    left: 50%;
    bottom: 3%;
    margin-left: -220px;
    padding: 0px;
    background-color: transparent;
    border: 0px;
    transform-origin: center center;
    z-index: 20;
}

.horiz_button:hover {
    transform: scale(1.06);
}

.horiz_button:active {
    transform: scale(0.98);
}

.horiz_button_image {
    position: absolute;
    left: 0px;
    top: 0px;
    pointer-events: none;
}

.horiz_button_hover {
    display: none;
}

.horiz_button:hover .horiz_button_default {
    display: none;
}

.horiz_button:hover .horiz_button_hover {
    display: block;
}

.horiz_button_label {
    position: absolute;
    left: 0px;
    top: 36px;

    pointer-events: none;
}

.submenu_cursor_image {
    position: absolute;
    width: 150px;
    height: 150px;
    display: none;
    pointer-events: none;
    z-index: 9999;
}

/* ──────────────────────────────────────────────────────────────────────
 * 크레딧 ID 카드 확대 모달
 * 카드 클릭 시 화면 중앙으로 확대. 뒷배경(이미 블러된 메인 메뉴) 위에 어두운
 * 오버레이를 더 얹어 블러/딤 느낌을 준다. 선택/비활성 상태는 Lua가 SetProperty로 그린다.
 * (display:none → Lua open_card_modal에서 block) */
#credits_card_modal {
    position: absolute;
    left: 0px;
    top: 0px;
    width: 100%;
    height: 100%;
    display: none;
    z-index: 50;
}

/* 뒷배경 딤(블러 대용) — Lua가 opacity 0→1로 페이드인.
   모달이 열리면 선명한 크레딧 전경은 Lua가 숨기고, 그 뒤의 블러 처리된 메인 메뉴
   배경 위에 이 짙은 딤을 얹어 "배경 전체 블러" 느낌을 만든다. */
#credits_modal_dim {
    position: absolute;
    left: 0px;
    top: 0px;
    width: 100%;
    height: 100%;
    background-color: #00000099;
}

/* 확대된 카드: 화면 중앙. 높이 기준으로 키우고 폭은 비율(auto)대로.
   Lua가 transform(translate -50% -50% + scale)로 등장 애니메이션을 준다. */
#credits_modal_card {
    position: absolute;
    left: 50%;
    top: 44%;
    height: 62%;
    width: auto;
    transform: translate(-50%, -50%);
    transform-origin: center center;
}

/* 우측 상단 하얀색 X 닫기 버튼 */
#credits_modal_close {
    position: absolute;
    right: 4%;
    top: 6%;
    width: 88px;
    height: 88px;
    margin: 0px;
    padding: 0px;
    background-color: transparent;
    border: 0px;
    color: #ffffff;
    font-family: Galmuri;
    font-weight: bold;
    font-size: 76px;
    line-height: 88px;
    text-align: center;
    transform-origin: center center;
    font-effect: shadow(2px 2px #000000aa);
}

#credits_modal_close:hover {
    transform: scale(1.12);
}

/* 카드 하단 교육생증/사원증 전환 버튼 묶음 (가운데 정렬) */
#credits_modal_buttons {
    position: absolute;
    left: 50%;
    bottom: 8%;
    width: 720px;
    height: 84px;
    margin-left: -360px;
}

.credits_modal_switch_button {
    position: absolute;
    top: 0px;
    width: 340px;
    height: 84px;
    margin: 0px;
    padding: 0px;
    background-color: #00000099;
    border-width: 3px;
    border-color: #ffffffcc;
    border-radius: 14px;
    color: #ffffff;
    font-family: Galmuri;
    font-weight: bold;
    font-size: 36px;
    text-align: center;
    line-height: 84px;
    font-effect: shadow(2px 2px #000000aa);
}

.credits_modal_switch_button:hover {
    background-color: #ffffff22;
}

#credits_modal_btn_trainee {
    left: 0px;
}

#credits_modal_btn_employee {
    right: 0px;
}
