}

.score_row {
    position: absolute;
    left: 0px;
    width: 100%;
    height: 64px;
    color: #000000;
    font-family: YoonGothic;
    font-weight: normal;
    font-size: 28px;
    line-height: 64px;
    text-align: center;
    border-bottom-width: 2px;
    border-bottom-color: #000000;
}

#score_row_1 { top: 62px; }
#score_row_2 { top: 126px; }
#score_row_3 { top: 190px; }
#score_row_4 { top: 254px; }
#score_row_5 { top: 318px; }

.score_rank {
    position: absolute;
    left: 0%;
    top: 0px;
    width: 10%;
}

.score_name {
    position: absolute;
    left: 10%;
    top: 0px;
    width: 24%;
}

.score_count {
    position: absolute;
    left: 34%;
    top: 0px;
    width: 20%;
}

.score_value {
    position: absolute;
    left: 54%;
    top: 0px;
    width: 20%;
}

.score_date {
    position: absolute;
    left: 74%;
    top: 0px;
    width: 26%;
}

#score_empty_text {
