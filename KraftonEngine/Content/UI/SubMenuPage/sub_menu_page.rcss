}

.simple_card_title {
    display: none;
}

.simple_line {
    position: absolute;
    left: 36px;
    width: 1400px;
    height: 52px;
    color: #ffffff;
    font-size: 34px;
    line-height: 52px;
}


.credits_card {
    height: 730px;
    top: -20px;
}

#credits_developers_team {
    left: 0px;
    top: 15px;
    width: 100%;
    text-align: center;
    font-size: 36px;
}

#credits_developers_logo {
    display: inline-block;
    width: 400px;
    height: auto;
    vertical-align: middle;
    margin-left: 0px;
    margin-bottom: 15px;
}

/*
 * ID 카드 4장 가로 배치
 * ─────────────────────────────────────────────────
 * CARD_W = 13%   ← 카드 표시 너비
 * GAP    =  5%   ← 카드 사이 실제 간격
 * STRIDE = 18%   ← CARD_W + GAP
 * START  = 17%   ← 좌우 여백 대칭: (100 - 4×13 - 3×5) / 2 = 16.5 ≈ 17
 *
 * left[n] = START + n × STRIDE
 *
 * 카드 수·간격 바꿀 때: CARD_W·GAP 조정 → STRIDE 재계산 → START = (100 - 4×CARD_W - 3×GAP) / 2
 * ─────────────────────────────────────────────────
 */
.credits_id_card {
    position: absolute;
    top: 150px;
    width: 13%;   /* CARD_W */
    height: auto;
    /* 플립(scale X) 연출이 카드 중심을 기준으로 돌도록 */
    transform-origin: center center;
}

#credits_id_card_1 { left: 17%; }   /* START + 0×STRIDE */
#credits_id_card_2 { left: 35%; }   /* START + 1×STRIDE */
#credits_id_card_3 { left: 53%; }   /* START + 2×STRIDE */
#credits_id_card_4 { left: 71%; }   /* START + 3×STRIDE */

#credits_special_thanks {
    top: 530px;
    left: 36px;
    right: 36px;
    width: auto;
    text-align: right;
}

#credits_hint {
    top: 650px;
    left: 36px;
    right: 36px;
    width: auto;
    text-align: right;
    color: #fff2a8;
}

/* 스코어보드: scoreboard.json에서 읽은 값을 Lua가 각 row에 채운다 */
.scoreboard_card {
    height: 650px;
}

#scoreboard_month_title {
