    text-align: center;
    line-height: 52px;
}

.scoreboard_nav_button:hover {
    background-color: #ffffff66;
}

.scoreboard_nav_button:active {
    background-color: #ffffff66;
}

#scoreboard_prev_button {
    left: 0px;
}

#scoreboard_next_button {
