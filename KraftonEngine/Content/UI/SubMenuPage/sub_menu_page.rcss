    width: 50%;
    height: 100%;
    pointer-events: none;
}

.controls_close_button .horiz_button_label {
    position: absolute;
    top: 50%;
    left: 0px;
    width: 100%;
    transform: translateY(-50%);
    text-align: center;
    pointer-events: none;
}

.controls_close_button .horiz_button_hover {
    display: none;
}

.controls_close_button:hover .horiz_button_default {
    display: none;
}

.controls_close_button:hover .horiz_button_hover {
    display: block;
}

/* 스코어보드/크레딧 공통 카드 */
