body {
    margin: 0px;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background-color: transparent;

}

/* Lua에서 SetProperty("display", ...)로 보이기/숨기기를 제어한다 */
#page_root {
    position: absolute;
    left: 0px;
    top: 0px;
    width: 100%;
    height: 100%;
    display: none;
}

/* 화면 전체를 검은색 30%로 덮는 레이어
   주의: 이 RCSS는 rgba()/rgb() 함수 문법을 지원하지 않는다 (다른 화면도 전부 8자리 HEX 사용).
   #RRGGBBAA 에서 AA = 0.30 * 255 ≈ 0x4D */
#page_dim {
    position: absolute;
    left: 0px;
    top: 0px;
    width: 100%;
    height: 100%;
    background-color: #0000004D;
    z-index: 10;
}

/* 우측 상단 Back 버튼: "Back" 텍스트 + 화살표 아이콘, 텍스트는 흰색 */
#page_back_button {
    position: absolute;
    right: 5%;
    top: 6%;
    width: 290px;
    height: 98px;
    margin: 0px;
    padding: 0px;
    background-color: transparent;
    border: 0px;
    transform-origin: center center;
    z-index: 20;
}

#page_back_button:hover {
    transform: scale(1.08);
}

#page_back_label {
    position: absolute;
    right: 96px;
    top: 22px;
    font-family: Galmuri;
    font-weight: bold;
    color: #ffffff;
    font-size: 48px;
    line-height: 54px;
}

#page_back_icon {
    position: absolute;
    right: 0px;
    top: 7px;
    width: 84px;
    height: 84px;
    pointer-events: none;
}

#page_body {
    position: absolute;
    left: 5%;
    top: 21%;
    width: 90%;
    height: 62%;
    z-index: 20;
}

.page_body_section {
    position: absolute;
    left: 0px;
    top: 0px;
    width: 100%;
    height: 100%;
    display: none;
}

/* Options: RmlUi의 inline/relative 흐름 차이를 피하려고 전부 절대 좌표로 배치한다 */
.option_group_label {
    position: absolute;
    left: 0px;
    width: 520px;
    height: 62px;
}

#sound_volume_label {
    top: 180px;
}

#input_mode_label {
    top: 274px;
}

.option_group_label_icon {
    position: absolute;
    left: 0px;
    top: 3px;
    width: 56px;
    height: 56px;
}

.option_group_label_text {
    position: absolute;
    left: 68px;
    top: 5px;
    font-family: Galmuri;
    font-weight: bold;
    color: #ffffff;
    font-size: 44px;
    line-height: 52px;
}

.option_row {
    position: absolute;
    left: 0px;
    width: 100%;
    height: 76px;
    background-color: #ffffff30;
    border-width: 2px;
    border-color: #ffffff55;
    border-radius: 14px;
}

#sfx_volume_row {
    top: 262px;
}

#bgm_volume_row {
    top: 350px;
}

.option_row_name {
    position: absolute;
    left: 36px;
    top: 18px;
    font-family: Galmuri;
    font-weight: bold;
    color: #ffffff;
    font-size: 34px;
    line-height: 42px;
}

.value_step_button {
    position: absolute;
    top: 12px;
    width: 52px;
    height: 52px;
    margin: 0px;
    padding: 0px;
    background-color: #ffffff22;
    border-width: 2px;
    border-color: #ffffffaa;
    border-radius: 10px;
    color: #ffffff;
    font-size: 34px;
    text-align: center;
    line-height: 52px;
}

.value_step_button:hover {
    background-color: #ffffff88;
}

.value_down {
    right: 220px;
}

.value_up {
    right: 36px;
}

.option_value_text {
    position: absolute;
    right: 92px;
    top: 12px;
    width: 128px;
    height: 52px;
    font-family: Galmuri;
    font-weight: bold;
    color: #ffffff;
    font-size: 34px;
    text-align: center;
    line-height: 52px;
}

/* 입력 모드 선택 행: settings_input_* 아이콘을 작게 표시한다 */
.input_mode_row {
    position: absolute;
    left: 0px;
    width: 100%;
    height: 86px;
    margin: 0px;
    padding: 0px;
    background-color: #00000040;
    border-radius: 14px;
    border-width: 2px;
    border-color: #00000000;
    text-align: left;
}

#input_mode_mouse_key {
    top: 356px;
}

#input_mode_gamepad {
    top: 456px;
}

.input_mode_row:hover {
    background-color: #ffffff2c;
}

.input_mode_row.selected {
    background-color: #ffd9664d;
    border-color: #ffd966ff;
}

.input_mode_icon {
    position: absolute;
    left: 24px;
    top: 14px;
    width: 58px;
    height: 58px;
    pointer-events: none;
}

.input_mode_text {
    position: absolute;
    left: 104px;
    top: 22px;
    color: #ffffff;
    font-size: 34px;
    line-height: 44px;
    pointer-events: none;
}

/* Controls (플레이 방법) 선택/팝업 레이아웃 */
#controls_choice_buttons {
    position: absolute;
    left: 0px;
    top: 0px;
    width: 100%;
    height: 650px;
    display: block;
}

/* Pause 화면의 2버튼 UI를 재사용하되, 이 화면에서만 좌/우 배치 */
.controls_choice_button {
    position: absolute;
    top: 50%;
    margin-top: -52px;
    padding: 0px;
    border: 0px;
    background-color: transparent;
    transform-origin: center center;
}

#controls_tab_game {
    left: 50%;
    margin-left: -500px;
}

#controls_tab_input {
    left: 50%;
    margin-left: 60px;
}

.controls_choice_button:hover {
    transform: scale(1.06);
}

.controls_choice_button:active {
    transform: scale(0.98);
}

.controls_choice_button_img {
    position: absolute;
    left: 0px;
    top: 0px;
    pointer-events: none;
}

.controls_choice_btn_hover {
    display: none;
}

.controls_choice_button:hover .controls_choice_btn_default {
    display: none;
}

.controls_choice_button:hover .controls_choice_btn_hover {
    display: block;
}

.controls_choice_button_label {
    position: absolute;
    left: 0px;
    top: 26px;
    width: 100%;
    height: 52px;
    pointer-events: none;
}

.controls_body {
    position: absolute;
    left: 0px;
    top: 0px;
    width: 100%;
    height: 650px;
    display: none;
}

/* 입력 장치 선택 버튼 (아이콘 + 텍스트) */
.controls_device_button {
    position: absolute;
    top: 0px;
    width: 300px;
    height: 76px;
    margin: 0px;
    padding: 0px;
    background-color: #00000099;
    border-width: 3px;
    border-color: #ffffffcc;
    border-radius: 12px;
}

.controls_device_button:hover {
    background-color: #ffffff20;
}

/* 두 버튼 가운데 정렬: 각 300px, 간격 40px → 총 640px */
#controls_device_km {
    left: 50%;
    margin-left: -320px;
}

#controls_device_gp {
    left: 50%;
    margin-left: 20px;
}

.controls_device_icon {
    position: absolute;
    left: 10px;
    top: 10px;
    width: 56px;
    height: 56px;
