}

/* 각 body 내부 닫기 버튼 — 우측 하단 고정 */
.controls_close_button {
    position: absolute;
    bottom: -170px;
    right: -100px;
    width: 264px;
    height: 104px;
    padding: 0px;
    background-color: transparent;
    border: 0px;
    transform-origin: center center;
}

.controls_close_button:hover {
    transform: scale(1.06);
}

.controls_close_button:active {
    transform: scale(0.98);
}

.controls_close_button .horiz_button_image {
    position: absolute;
    left: 110px;
